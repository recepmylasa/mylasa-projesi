// storage.rules — silme izni eklendi
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    match /profile_photos/{userId}/{fileName} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId &&
                      request.resource.size < 5 * 1024 * 1024 &&
                      request.resource.contentType.matches('image/.*');
    }

    match /post_media/{userId}/{fileName} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /raw-uploads/{userId}/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // İşlenmiş klipler
    match /clips_media/{userId}/{fileName} {
      allow read;
    }

    // HİKAYELER: sadece sahibi yükleyebilir, silebilir, herkes okuyabilir
    match /hikaye_media/{userId}/{fileName} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId &&
                    request.resource.size < 50 * 1024 * 1024 &&
                    (request.resource.contentType.matches('image/.*') ||
                     request.resource.contentType.matches('video/.*'));
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
