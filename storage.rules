rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    match /profile_photos/{userId}/{fileName} {
      allow read;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    match /post_media/{userId}/{fileName} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /checkins/{userId}/{fileName} {
      allow read;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    match /raw-uploads/{userId}/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /clips_media/{userId}/{fileName} {
      allow read;
    }

    match /hikaye_media/{userId}/{fileName} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId
                    && request.resource.size < 50 * 1024 * 1024
                    && (request.resource.contentType.matches('image/.*')
                        || request.resource.contentType.matches('video/.*'));
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // ROTA MEDYASI — Firestore lookup (default) ile
    match /route_media/{routeId}/{stopId}/{fileName} {
      function isOwner() {
        return request.auth != null
          && get(/databases/(default)/documents/routes/$(routeId)).data.ownerId == request.auth.uid;
      }
      function isPublic() {
        return get(/databases/(default)/documents/routes/$(routeId)).data.visibility == "public";
      }

      allow read: if isPublic() || isOwner();

      allow write: if isOwner()
        && (
          (request.resource.contentType.matches('image/.*') && request.resource.size <= 10 * 1024 * 1024) ||
          (request.resource.contentType.matches('video/.*') && request.resource.size <= 50 * 1024 * 1024)
        );

      allow delete: if isOwner();
    }

    match /{allPaths=**} { allow read, write: if false; }
  }
}
