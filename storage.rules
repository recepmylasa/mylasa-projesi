// storage.rules
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() { return request.auth != null; }

    /* --- DÜNYAYA AÇIK VARLIKLAR --- */
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    /* ✅ YENİ STANDART — ROUTE KAPAKLARI (minimum + kontrollü)
       route-covers/{uid}/{routeId}/{file}
       - read: public (profil/keşif için)
       - write: sadece owner */
    match /route-covers/{uid}/{routeId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    /* ⚠️ ESKİ YOL (underscore) — geriye dönük okuma açık, yazma kapalı
       (mevcut kapak URL’leri kırılmasın) */
    match /route_covers/{routeId}/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    /* --- Uygulama medyaları --- */
    match /route_media/{routeId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /post_media/{postId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /clip_media/{clipId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    /* --- Diğer her şey kapalı --- */
    match /{everything=**} {
      allow read, write: if false;
    }
  }
}
