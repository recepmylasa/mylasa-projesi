rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() { return request.auth != null; }

    /* --- DÜNYAYA AÇIK VARLIKLAR --- */
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    /* --- ROUTE KAPAKLARI (Kapak seç upload + server-side cover) --- */
    match /route_covers/{routeId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    /* --- Uygulama medyaları --- */
    match /route_media/{routeId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /post_media/{postId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /clip_media/{clipId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    /* --- Diğer her şey kapalı --- */
    match /{everything=**} {
      allow read, write: if false;
    }
  }
}
