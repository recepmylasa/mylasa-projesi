// storage.rules — TAM DOSYA
rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() { return request.auth != null; }

    /* --- DÜNYAYA AÇIK VARLIKLAR --- */
    // Örn: public/share/default-route.png (OG görselleri vs.)
    match /public/{allPaths=**} {
      allow read: if true;          // token gerektirmez
      allow write: if isSignedIn(); // istersen burayı false yapıp sadece console’dan yükleyebilirsin
    }

    /* --- Uygulama medyaları --- */
    match /route_media/{routeId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /post_media/{postId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /clip_media/{clipId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    /* --- Diğer her şey kapalı --- */
    match /{everything=**} {
      allow read, write: if false;
    }
  }
}
