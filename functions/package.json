    "ffmpeg-static": "^5.2.0",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^4.9.0",
    "fluent-ffmpeg": "^2.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.24",
    "rimraf": "^5.0.10",
    "typescript": "^5.9.3"
  }
