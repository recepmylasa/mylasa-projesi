rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers
    function devWindow() { return request.time < timestamp.date(2030, 1, 1); }
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // EMİR 07: Catch-all okuma kuralı routeDrops/drops'u ezmesin diye
    // Bu iki subcollection için "self-only read" zorunlu kılıyoruz.
    function isSensitiveUserDropPath(p) {
      return p.matches('users/[^/]+/routeDrops/[^/]+') || p.matches('users/[^/]+/drops/[^/]+');
    }
    function isSelfSensitiveUserDropPath(p) {
      return isSignedIn()
        && (
          p.matches('users/' + request.auth.uid + '/routeDrops/[^/]+')
          || p.matches('users/' + request.auth.uid + '/drops/[^/]+')
        );
    }

    /* =================== USERS =================== */
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, delete: if isOwner(userId);
      allow update: if isOwner(userId);

      // Takipçiler (followers)
      match /followers/{followerUid} {
        allow read: if isOwner(userId);
        allow create: if isSignedIn()
          && followerUid == request.auth.uid
          && followerUid != userId
          && request.resource.id == request.auth.uid
          && request.resource.data.followerId == request.auth.uid
          && request.resource.data.createdAt is timestamp;
        allow delete: if isSignedIn() && followerUid == request.auth.uid;
        allow update: if false;
      }

      // following (salt owner read)
      match /following/{targetUid} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      // /users/{uid}/saved/{contentId}
      match /saved/{docId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && request.resource.id == request.resource.data.contentId
          && request.resource.data.contentId is string
          && request.resource.data.type in ['post','clip','story']
          && request.resource.data.authorId is string;
        allow update: if false;
        allow delete: if isOwner(userId);
      }

      // badges: PUBLIC READ
      match /badges/{badgeId} { allow read: if true; allow create, update, delete: if false; }

      // stats: owner-only read
      match /stats/{docId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      // EMİR 07: Route drops — read self, write kapalı (sadece server yazar)
      match /routeDrops/{routeId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      // EMİR 07: Drops log — read self, write kapalı (sadece server yazar)
      match /drops/{dropId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
    }

    match /usernames/{username} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
    }

    /* =================== LOCATIONS (özet) =================== */
    match /locations/{userId} {
      allow write: if isOwner(userId);
      allow read: if isSignedIn() && devWindow();
    }

    /* ============ CHECK-INS (mobil akış) ============ */
    match /checkins/{checkinId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.placeId is string
        && (request.resource.data.coordinates is list)
        && (request.resource.data.coordinates.size() == 2)
        && (request.resource.data.coordinates[0] is number)
        && (request.resource.data.coordinates[1] is number);
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    /* ===== POSTS / HIKAYELER / CLIPS (özet) ===== */
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    match /hikayeler/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    match /clips/{clipId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    /* =================== CONTENT + RATINGS =================== */
    match /content/{contentId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.type in ['post','story','clip'];

      allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;

      match /ratings/{raterId} {
        allow read: if isSignedIn();

        allow create: if isSignedIn()
          && raterId == request.auth.uid
          && request.resource.data.raterId == request.auth.uid
          && request.resource.data.value is int
          && request.resource.data.value >= 1
          && request.resource.data.value <= 5
          && exists(/databases/$(database)/documents/content/$(contentId))
          && get(/databases/$(database)/documents/content/$(contentId)).data.authorId != request.auth.uid;

        allow update: if isSignedIn()
          && raterId == request.auth.uid
          && request.resource.data.raterId == resource.data.raterId
          && request.resource.data.value is int
          && request.resource.data.value >= 1
          && request.resource.data.value <= 5
          && exists(/databases/$(database)/documents/content/$(contentId))
          && get(/databases/$(database)/documents/content/$(contentId)).data.authorId != request.auth.uid;

        allow delete: if false;
      }
    }

    /* ===== LABUBU SERİSİ (public read) ===== */
    match /series/{seriesId} { allow read: if true; allow write: if false; }

    /* Legendary cap’ler */
    match /global_legendary_caps/{docId} {
      allow read: if isSignedIn() || devWindow();
      allow write: if false;
    }

    // ==================== ADIM-9: FOLLOWS (legacy) ====================
    match /follows/{pairId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.followerId == request.auth.uid
        && request.resource.data.followeeId is string
        && request.resource.data.followerId != request.resource.data.followeeId
        && request.resource.id == (request.auth.uid + "_" + request.resource.data.followeeId);
      allow delete: if isSignedIn() && resource.data.followerId == request.auth.uid;
      allow update: if false;
    }

    // ==================== ROUTES + STOPS =====================
    match /routes/{routeId} {
      // public OR owner OR followers
      allow read: if
        resource.data.visibility == "public"
        || (isSignedIn() && resource.data.ownerId == request.auth.uid)
        || (isSignedIn()
            && resource.data.visibility == "followers"
            && (
              exists(/databases/$(database)/documents/users/$(resource.data.ownerId)/followers/$(request.auth.uid))
              || exists(/databases/$(database)/documents/follows/$(request.auth.uid + "_" + resource.data.ownerId))
            )
        );

      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      // --- EKLENDİ: reverseGeocode ve yorumlar alt koleksiyonları ---
      match /areas/{areaId} {
        allow read, list: if true;   // herkes okuyabilir (reverseGeocode)
        allow write: if false;       // sadece backend
      }

      match /comments/{commentId} {
        allow read, list: if
          get(/databases/$(database)/documents/routes/$(routeId)).data.visibility == "public"
          || (isSignedIn()
              && get(/databases/$(database)/documents/routes/$(routeId)).data.ownerId == request.auth.uid)
          || (isSignedIn()
              && get(/databases/$(database)/documents/routes/$(routeId)).data.visibility == "followers"
              && (
                exists(/databases/$(database)/documents/users/$(get(/databases/$(database)/documents/routes/$(routeId)).data.ownerId)/followers/$(request.auth.uid))
                || exists(/databases/$(database)/documents/follows/$(request.auth.uid + "_" + get(/databases/$(database)/documents/routes/$(routeId)).data.ownerId))
              ));
        allow create: if isSignedIn()
          && request.resource.data.routeId == routeId
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.text is string;
        allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
        allow update: if false;
      }

      match /stops/{stopId} {
        // stop read → route görünürlüğü/ownership’e göre
        allow read: if
          get(/databases/$(database)/documents/routes/$(routeId)).data.visibility == "public"
          || (isSignedIn()
              && get(/databases/$(database)/documents/routes/$(routeId)).data.ownerId == request.auth.uid)
          || (isSignedIn()
              && get(/databases/$(database)/documents/routes/$(routeId)).data.visibility == "followers"
              && (
                exists(/databases/$(database)/documents/users/$(get(/databases/$(database)/documents/routes/$(routeId)).data.ownerId)/followers/$(request.auth.uid))
                || exists(/databases/$(database)/documents/follows/$(request.auth.uid + "_" + get(/databases/$(database)/documents/routes/$(routeId)).data.ownerId))
              )
          );

        // stop write → sadece route sahibi
        allow create, update, delete: if isSignedIn()
          && get(/databases/$(database)/documents/routes/$(routeId)).data.ownerId == request.auth.uid;

        // --- stops/{stopId}/media alt koleksiyonu ---
        match /media/{mediaId} {
          allow read: if
            get(/databases/$(database)/documents/routes/$(routeId)).data.visibility == "public"
            || (isSignedIn()
                && get(/databases/$(database)/documents/routes/$(routeId)).data.ownerId == request.auth.uid)
            || (isSignedIn()
                && get(/databases/$(database)/documents/routes/$(routeId)).data.visibility == "followers"
                && (
                  exists(/databases/$(database)/documents/users/$(get(/databases/$(database)/documents/routes/$(routeId)).data.ownerId)/followers/$(request.auth.uid))
                  || exists(/databases/$(database)/documents/follows/$(request.auth.uid + "_" + get(/databases/$(database)/documents/routes/$(routeId)).data.ownerId))
                )
            );

          // media write → sadece route sahibi + tip/url kontrolü
          allow create, update, delete: if isSignedIn()
            && get(/databases/$(database)/documents/routes/$(routeId)).data.ownerId == request.auth.uid
            && request.resource.data.type in ['image','video']
            && request.resource.data.url is string
            && request.resource.data.ownerId == request.auth.uid;
        }
      }
    }

    // ==================== RATINGS ====================
    match /route_ratings/{rid_uid} {
      allow read: if true;
      allow create, update: if isSignedIn()
        && request.resource.data.routeId is string
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.value is int
        && request.resource.data.value >= 1 && request.resource.data.value <= 5
        && (get(/databases/$(database)/documents/routes/$(request.resource.data.routeId)).data.ownerId != request.auth.uid);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /stop_ratings/{sid_uid} {
      allow read: if true;
      allow create, update: if isSignedIn()
        && request.resource.data.stopId is string
        && request.resource.data.routeId is string
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.value is int
        && request.resource.data.value >= 1 && request.resource.data.value <= 5
        && (get(/databases/$(database)/documents/routes/$(request.resource.data.routeId)).data.ownerId != request.auth.uid);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    /* =================== TELEMETRY (Share) =================== */
    match /metrics_share_events/{docId} {
      allow read: if false;
      allow write: if false;
    }

    match /metrics_share_agg/daily/{docId} {
      allow read: if isSignedIn() && request.auth.token.admin == true;
      allow write: if false;
    }

    /* =================== CATCH-ALL (DEV OKUMA) =================== */
    match /{document=**} {
      allow read: if (isSignedIn() || devWindow())
        && (!isSensitiveUserDropPath(document) || isSelfSensitiveUserDropPath(document));
      allow write: if false;
    }
  }
}
