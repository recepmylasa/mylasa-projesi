rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers
    function listOrEmpty(x) { return (x is list) ? x : []; }
    // DEV okuma penceresi (UZATILDI)
    function devWindow() { return request.time < timestamp('2030-01-01T00:00:00Z'); }
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    /* =================== USERS =================== */
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, delete: if isOwner(userId);
      allow update: if isOwner(userId);

      // /users/{uid}/saved/{contentId}
      match /saved/{docId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
          && request.resource.id == request.resource.data.contentId
          && request.resource.data.contentId is string
          && request.resource.data.type in ['post','clip','story']
          && request.resource.data.authorId is string;
        allow update: if false;
        allow delete: if isOwner(userId);
      }
    }

    match /usernames/{username} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
    }

    /* =================== LOCATIONS (özet) =================== */
    match /locations/{userId} {
      allow write: if isOwner(userId);
      allow read: if isSignedIn() && devWindow();
    }

    /* ============ CHECK-INS (mobil akış) ============ */
    // Kullanıcılar kendi check-in kayıtlarını oluşturabilir/silebilir.
    // Kayıtlar büyük oranda immutable; update kapalıdır.
    match /checkins/{checkinId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.placeId is string
        // coordinates: [lng, lat]
        && (request.resource.data.coordinates is list)
        && (request.resource.data.coordinates.size() == 2)
        && (request.resource.data.coordinates[0] is number)
        && (request.resource.data.coordinates[1] is number);

      allow update: if false;

      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    /* ===== POSTS / HIKAYELER / CLIPS (özet) ===== */
    match /posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    match /hikayeler/{id} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    match /clips/{clipId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    /* =================== CONTENT + RATINGS =================== */
    match /content/{contentId} {
      allow read: if isSignedIn();

      // İçeriği sadece sahibi oluşturabilsin (kimlik taklidi engeli)
      allow create: if isSignedIn()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.type in ['post','story','clip'];

      allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;

      // /content/{contentId}/ratings/{raterId}
      match /ratings/{raterId} {
        allow read: if isSignedIn();

        // Yeni oy: sadece kendi adına, 1..5 puan ve kendi içeriğini oylayamaz
        allow create: if isSignedIn()
          && raterId == request.auth.uid
          && request.resource.data.raterId == request.auth.uid
          && request.resource.data.value is int
          && request.resource.data.value >= 1
          && request.resource.data.value <= 5
          && exists(/databases/$(database)/documents/content/$(contentId))
          && get(/databases/$(database)/documents/content/$(contentId)).data.authorId != request.auth.uid;

        // Güncelleme: yalnızca puan değişebilir, rater sabit; yine 1..5 ve kendi içeriği değil
        allow update: if isSignedIn()
          && raterId == request.auth.uid
          && request.resource.data.raterId == resource.data.raterId
          && request.resource.data.value is int
          && request.resource.data.value >= 1
          && request.resource.data.value <= 5
          && exists(/databases/$(database)/documents/content/$(contentId))
          && get(/databases/$(database)/documents/content/$(contentId)).data.authorId != request.auth.uid;

        allow delete: if false;
      }
    }

    /* ===== LABUBU SERİSİ (public read, admin write yok) ===== */
    match /series/{seriesId} {
      allow read: if true;
      allow write: if false;
    }

    /* Legendary cap’ler (UI için okuma serbest/DEV’te de açık) */
    match /global_legendary_caps/{docId} {
      allow read: if isSignedIn() || devWindow();
      allow write: if false;
    }

    /* =================== CATCH-ALL (DEV OKUMA) =================== */
    match /{document=**} {
      // Kimlik varsa her zaman; yoksa sadece dev penceresinde oku
      allow read: if isSignedIn() || devWindow();
      allow write: if false;
    }

    // ============================================================
    // ====================  ADIM-3 EK BLOKLAR  ===================
    // ============================================================

    // ——— ROUTES (READ/WRITE GUARD) ———
    match /routes/{routeId} {
      // public ise herkes okuyabilir; private/followers basitçe owner'a açık (ileri adımlarda genişler)
      allow read: if resource.data.visibility == "public"
                  || (request.auth != null && resource.data.ownerId == request.auth.uid);

      // Sadece sahibi oluşturabilir/güncelleyebilir/silebilir
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;

      // stops alt koleksiyonu
      match /stops/{stopId} {
        allow read: if get(/databases/$(database)/documents/routes/$(routeId)).data.visibility == "public"
                    || (request.auth != null && get(/databases/$(database)/documents/routes/$(routeId)).data.ownerId == request.auth.uid);
        allow create, update, delete: if request.auth != null &&
          get(/databases/$(database)/documents/routes/$(routeId)).data.ownerId == request.auth.uid;

        // ====== ADIM-6: MEDIA alt koleksiyonu ======
        match /media/{mediaId} {
          // Rota public ise herkes okuyabilir, değilse yalnızca sahibi
          allow read: if get(/databases/$(database)/documents/routes/$(routeId)).data.visibility == "public"
                      || (request.auth != null
                          && get(/databases/$(database)/documents/routes/$(routeId)).data.ownerId == request.auth.uid);

          // Sadece rota sahibi yazabilir/güncelleyebilir/silebilir
          allow create, update, delete: if request.auth != null
            && get(/databases/$(database)/documents/routes/$(routeId)).data.ownerId == request.auth.uid
            // alan doğrulamaları
            && request.resource.data.type in ['image','video']
            && request.resource.data.url is string
            && request.resource.data.ownerId == request.auth.uid
            && request.resource.data.w is number
            && request.resource.data.h is number
            && request.resource.data.size is number
            && request.resource.data.createdAt is timestamp;
        }
      }
    }

    // ——— RATINGS ———
    match /route_ratings/{rid_uid} {
      allow read: if true; // oylama toplamları UI için okunabilir
      allow create, update: if request.auth != null
        && request.resource.data.routeId is string
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.value is int
        && request.resource.data.value >= 1 && request.resource.data.value <= 5
        // Kendi rotana oy verme:
        && (get(/databases/$(database)/documents/routes/$(request.resource.data.routeId)).data.ownerId != request.auth.uid);
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /stop_ratings/{sid_uid} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.data.stopId is string
        && request.resource.data.routeId is string
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.value is int
        && request.resource.data.value >= 1 && request.resource.data.value <= 5
        // Kendi durak/rotana oy verme:
        && (get(/databases/$(database)/documents/routes/$(request.resource.data.routeId)).data.ownerId != request.auth.uid);
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
