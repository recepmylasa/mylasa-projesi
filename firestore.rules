rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function listOrEmpty(x) { return (x is list) ? x : []; }
    function devWindow() { return request.time < timestamp('2025-10-01T00:00:00Z'); }

    /* ===== USERS ===== */
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;

      match /saved/{docId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null
          && request.auth.uid == userId
          && request.resource.id == request.resource.data.contentId
          && request.resource.data.contentId is string
          && request.resource.data.type in ['post','clip','story']
          && request.resource.data.authorId is string;
        allow update: if false;
        allow delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /usernames/{username} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
    }

    /* ===== LOCATIONS (özet) ===== */
    match /locations/{userId} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && devWindow();
    }

    /* ===== POSTS/HIKAYELER/CLIPS (özet) ===== */
    match /posts/{postId}   { allow read: if request.auth != null; allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid; allow update, delete: if request.auth != null && resource.data.authorId == request.auth.uid; }
    match /hikayeler/{id}   { allow read: if request.auth != null; allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid; allow update, delete: if request.auth != null && resource.data.authorId == request.auth.uid; }
    match /clips/{clipId}   { allow read: if request.auth != null; allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid; allow update, delete: if request.auth != null && resource.data.authorId == request.auth.uid; }

    /* ===== CONTENT + RATINGS ===== */
    match /content/{contentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.authorId is string
        && request.resource.data.type in ['post','story','clip'];
      allow update, delete: if request.auth != null && resource.data.authorId == request.auth.uid;

      match /ratings/{raterId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && raterId == request.auth.uid
          && request.resource.data.raterId == request.auth.uid
          && request.resource.data.value is int
          && request.resource.data.value >= 1
          && request.resource.data.value <= 5
          && exists(/databases/$(database)/documents/content/$(contentId));
        allow update: if request.auth != null
          && raterId == request.auth.uid
          && request.resource.data.value is int
          && request.resource.data.value >= 1
          && request.resource.data.value <= 5;
        allow delete: if false;
      }
    }

    /* ====== LABUBU SERİSİ (public read, admin write) ====== */
    match /series/{seriesId} {
      allow read: if true;        // herkes okuyabilir (UI için gerekli)
      allow write: if false;      // yazma sadece Admin SDK (Functions) ile
    }

    /* Legendary cap’ler (UI okumazsa bile sorun yok) */
    match /global_legendary_caps/{docId} {
      allow read: if request.auth != null || devWindow();
      allow write: if false;
    }

    /* ===== Catch-all (dev okuma) ===== */
    match /{document=**} {
      allow read: if request.auth != null && devWindow();
      allow write: if false;
    }
  }
}
