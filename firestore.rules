rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* ---------------- Yardımcılar ---------------- */
    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }
    function isSharingLocation(userData) {
      return userData.isSharing == true;
    }
    function canRequesterSeeLocation(userData, requesterId) {
      return (userData.sharingMode == 'all_friends' &&
              userData.takipEdilenler != null &&
              requesterId in userData.takipEdilenler)
          || (userData.sharingMode == 'selected_friends' &&
              userData.sharingWhitelist != null &&
              requesterId in userData.sharingWhitelist);
    }
    function canReadLocation(userId, requesterId) {
      return isSharingLocation(getUserData(userId))
          && canRequesterSeeLocation(getUserData(userId), requesterId);
    }

    /* ---------------- USERS ---------------- */
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && request.auth.uid == userId;

      /* ----- SAVED (Bookmark) ----- */
      // Doc id'yi contentId ile aynı yazıyoruz (client öyle gönderiyor).
      match /saved/{docId} {
        // Sadece sahibi görebilir/listeleyebilir
        allow read: if request.auth != null && request.auth.uid == userId;

        // Oluşturma: sadece sahibi; alan kısıtları + varlık kontrolü
        allow create: if request.auth != null
          && request.auth.uid == userId
          && docId == request.resource.data.contentId
          && request.resource.data.contentId is string
          && request.resource.data.type in ['post','clip','story']
          && request.resource.data.authorId is string
          && ( !('mediaUrl' in request.resource.data) || request.resource.data.mediaUrl is string || request.resource.data.mediaUrl == null )
          && ( !('caption' in request.resource.data) || request.resource.data.caption is string )
          && ( !('createdAt' in request.resource.data) || request.resource.data.createdAt is timestamp )
          // İçerik dokümanı ana koleksiyonlardan birinde varsa
          && (
               exists(/databases/$(database)/documents/content/$(request.resource.data.contentId)) ||
               exists(/databases/$(database)/documents/posts/$(request.resource.data.contentId)) ||
               exists(/databases/$(database)/documents/clips/$(request.resource.data.contentId)) ||
               exists(/databases/$(database)/documents/hikayeler/$(request.resource.data.contentId))
             );

        // Update yok (toggle = delete/create)
        allow update: if false;

        // Silme: sahibi
        allow delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /usernames/{username} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
    }

    /* ---------------- LOCATIONS ---------------- */
    match /locations/{userId} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null &&
                   (request.auth.uid == userId || canReadLocation(userId, request.auth.uid));
    }

    /* ---------------- POSTS ---------------- */
    match /posts/{postId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid;

      // Güncelleme:
      // - Sahibi her alanı güncelleyebilir AMA authorId değiştirilemez
      // - Sahibi olmayanlar sadece yorum ekleyebilir (yorumlar boyu ↓ azalamaz)
      allow update: if request.auth != null && (
        (
          // sahip
          resource.data.authorId == request.auth.uid
          && request.resource.data.authorId == resource.data.authorId
        ) || (
          // sahibi değil → sadece yorumlar alanına ekleme
          !(request.resource.data.diff(resource.data).affectedKeys().hasAny([
            "authorId","mediaUrl","mediaType","storagePath",
            "tarih","createdAt","aciklama","mesaj","caption","location","begenenler"
          ]))
          && request.resource.data.yorumlar.size() >= resource.data.yorumlar.size()
        )
      );

      allow delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }

    /* ---------------- HİKAYELER ---------------- */
    match /hikayeler/{storyId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid;

      // Sahip full update (authorId sabit); başkası sadece sayaç/izleyen
      allow update: if request.auth != null && (
        (
          resource.data.authorId == request.auth.uid
          && request.resource.data.authorId == resource.data.authorId
        ) || (
          !(request.resource.data.diff(resource.data).affectedKeys().hasAny([
            "authorId","mediaUrl","mediaType","contentType","storagePath",
            "dosyaBoyutu","tarih","createdAt","authorUsername","authorProfilePic"
          ]))
          && request.resource.data.viewersCount >= resource.data.viewersCount
        )
      );

      allow delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }

    /* ---------------- CLIPS ---------------- */
    match /clips/{clipId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid;

      // Sahip: serbest ama authorId sabit.
      // Sahibi olmayan: yalnızca yorum ekleyebilir.
      allow update: if request.auth != null && (
        (
          resource.data.authorId == request.auth.uid
          && request.resource.data.authorId == resource.data.authorId
        ) || (
          !(request.resource.data.diff(resource.data).affectedKeys().hasAny([
            "authorId","mediaUrl","mediaType","storagePath",
            "tarih","createdAt","aciklama","mesaj","caption","location","begenenler"
          ]))
          && request.resource.data.yorumlar.size() >= resource.data.yorumlar.size()
        )
      );

      allow delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }

    /* ---------------- CHECKINS ---------------- */
    match /checkins/{checkinId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        canReadLocation(resource.data.userId, request.auth.uid)
      );
      allow update: if false;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    /* ---------------- NOTIFICATIONS ---------------- */
    match /notifications/{notificationId} {
      allow read, create: if request.auth != null;
      // Sadece alıcı güncelleyebilir ve 'to' değiştirilemez
      allow update: if request.auth != null
        && request.auth.uid == resource.data.to
        && request.resource.data.to == resource.data.to;
    }

    /* ---------------- CONTENT + RATINGS ---------------- */
    match /content/{contentId} {
      // Okuma: giriş yapmış herkes
      allow read: if request.auth != null;

      // CREATE: Herkes (auth) stub açabilir (type/authorId doğrulanır)
      allow create: if request.auth != null
        && request.resource.data.authorId is string
        && request.resource.data.type in ['post', 'story', 'clip'];

      // UPDATE/DELETE: sadece içerik sahibi, authorId sabit
      allow update, delete: if request.auth != null
        && resource.data.authorId == request.auth.uid
        && request.resource.data.authorId == resource.data.authorId;

      // Tekil oylar
      match /ratings/{raterId} {
        allow read: if request.auth != null;

        // Yeni oy
        allow create: if request.auth != null
          && raterId == request.auth.uid
          && request.resource.data.raterId == request.auth.uid
          && request.resource.data.authorId != request.auth.uid
          && request.resource.data.value is int
          && request.resource.data.value >= 1
          && request.resource.data.value <= 5
          && exists(/databases/$(database)/documents/content/$(contentId));

        // Kendi oyunu güncelle (authorId sabit olmalı)
        allow update: if request.auth != null
          && raterId == request.auth.uid
          && request.resource.data.raterId == request.auth.uid
          && request.resource.data.value is int
          && request.resource.data.value >= 1
          && request.resource.data.value <= 5
          && request.resource.data.authorId == resource.data.authorId;

        allow delete: if false;
      }
    }

    /* ---------------- USER STATS (yalnızca Admin SDK) ---------------- */
    match /userStats/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    /* ---------------- Catch-all ---------------- */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
