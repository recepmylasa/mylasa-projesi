rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* =================== Helpers =================== */
    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }
    function isSharingLocation(userData) {
      return userData.isSharing == true;
    }
    function canRequesterSeeLocation(userData, requesterId) {
      return (userData.sharingMode == 'all_friends' &&
              userData.takipEdilenler != null &&
              requesterId in userData.takipEdilenler)
          || (userData.sharingMode == 'selected_friends' &&
              userData.sharingWhitelist != null &&
              requesterId in userData.sharingWhitelist);
    }
    function canReadLocation(userId, requesterId) {
      return isSharingLocation(getUserData(userId))
          && canRequesterSeeLocation(getUserData(userId), requesterId);
    }

    /* =================== USERS =================== */
    match /users/{userId} {
      allow read: if request.auth != null;

      // Sahibinin create/delete hakkı
      allow create, delete: if request.auth != null && request.auth.uid == userId;

      // ► Güncelleme kuralları:
      // 1) Sahibi ise her alanı güncelleyebilir.
      // 2) Sahibi DEĞİLSE: SADECE "takipciler" alanında KENDİSİNİ tek bir ekleme/çıkarma yapabilir.
      allow update: if request.auth != null && (
        // (1) owner full control
        request.auth.uid == userId
        ||
        // (2) non-owner: follow/unfollow sadece 'takipciler' alanı
        (
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['takipciler'])
          &&
          (request.resource.data.takipciler is list)
          &&

          // FOLLOW veya UNFOLLOW şemasını doğrula
          (
            // ---- FOLLOW: eski liste yoksa (null) veya varsa +1 artmalı, sadece kendini eklemeli
            (
              // yeni listede kendisi olmalı
              (request.auth.uid in request.resource.data.takipciler)
              &&
              // eski boyut (0 veya mevcut) → yeni boyut tam +1
              (
                (resource.data.takipciler is list &&
                  request.resource.data.takipciler.size() == resource.data.takipciler.size() + 1
                  && !(request.auth.uid in resource.data.takipciler)
                  && request.resource.data.takipciler.hasAll(resource.data.takipciler)
                )
                ||
                (!(resource.data.takipciler is list) &&
                  request.resource.data.takipciler.size() == 1
                )
              )
            )
            ||
            // ---- UNFOLLOW: eski listede kendisi vardı, yeni listede yok ve –1 azaldı
            (
              (resource.data.takipciler is list)
              &&
              request.resource.data.takipciler.size() == resource.data.takipciler.size() - 1
              &&  (request.auth.uid in resource.data.takipciler)
              && !(request.auth.uid in request.resource.data.takipciler)
              &&  resource.data.takipciler.hasAll(request.resource.data.takipciler)
            )
          )
        )
      );

      /* ----- SAVED (Bookmark) ----- */
      match /saved/{docId} {
        // sadece sahibi
        allow read: if request.auth != null && request.auth.uid == userId;

        allow create: if request.auth != null
          && request.auth.uid == userId
          && request.resource.id == request.resource.data.contentId
          && request.resource.data.contentId is string
          && request.resource.data.type in ['post','clip','story']
          && request.resource.data.authorId is string
          && ( !('mediaUrl' in request.resource.data) || request.resource.data.mediaUrl is string || request.resource.data.mediaUrl == null )
          && ( !('caption' in request.resource.data) || request.resource.data.caption is string )
          && ( !('createdAt' in request.resource.data) || request.resource.data.createdAt is timestamp )
          && (
               exists(/databases/$(database)/documents/content/$(request.resource.data.contentId)) ||
               exists(/databases/$(database)/documents/posts/$(request.resource.data.contentId)) ||
               exists(/databases/$(database)/documents/clips/$(request.resource.data.contentId)) ||
               exists(/databases/$(database)/documents/hikayeler/$(request.resource.data.contentId))
             );

        allow update: if false;
        allow delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /usernames/{username} {
      allow read: if request.auth != null;
      // create zaten mevcutsa başarısız olur → benzersizlik garanti
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
    }

    /* =================== LOCATIONS =================== */
    match /locations/{userId} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null &&
                   (request.auth.uid == userId || canReadLocation(userId, request.auth.uid));
    }

    /* =================== POSTS =================== */
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;

      // owner full; non-owner yalnızca yorum ekleyebilir (commentsDisabled değilse)
      allow update: if request.auth != null && (
        (resource.data.authorId == request.auth.uid)
        ||
        (
          !(resource.data.commentsDisabled == true)
          &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['yorumlar'])
          &&
          (resource.data.yorumlar is list) && (request.resource.data.yorumlar is list)
          &&
          request.resource.data.yorumlar.size() == resource.data.yorumlar.size() + 1
          &&
          request.resource.data.yorumlar[resource.data.yorumlar.size()].userId == request.auth.uid
          &&
          request.resource.data.yorumlar[resource.data.yorumlar.size()].text is string
        )
      );

      allow delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }

    /* =================== HİKAYELER =================== */
    match /hikayeler/{storyId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;

      allow update: if request.auth != null && (
        resource.data.authorId == request.auth.uid ||
        (
          !(request.resource.data.diff(resource.data).affectedKeys().hasAny([
            "authorId","mediaUrl","mediaType","contentType","storagePath",
            "dosyaBoyutu","tarih","createdAt","authorUsername","authorProfilePic"
          ]))
          && request.resource.data.viewersCount >= resource.data.viewersCount
        )
      );

      allow delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }

    /* =================== CLIPS =================== */
    match /clips/{clipId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.authorId == request.auth.uid;

      allow update: if request.auth != null && (
        (resource.data.authorId == request.auth.uid)
        ||
        (
          !(resource.data.commentsDisabled == true)
          &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['yorumlar'])
          &&
          (resource.data.yorumlar is list) && (request.resource.data.yorumlar is list)
          &&
          request.resource.data.yorumlar.size() == resource.data.yorumlar.size() + 1
          &&
          request.resource.data.yorumlar[resource.data.yorumlar.size()].userId == request.auth.uid
          &&
          request.resource.data.yorumlar[resource.data.yorumlar.size()].text is string
        )
      );

      allow delete: if request.auth != null && resource.data.authorId == request.auth.uid;
    }

    /* =================== CHECKINS =================== */
    match /checkins/{checkinId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        canReadLocation(resource.data.userId, request.auth.uid)
      );
      allow update: if false;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    /* =================== NOTIFICATIONS =================== */
    match /notifications/{notificationId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.from == request.auth.uid;  // gönderen doğrulama
      allow update: if request.auth != null && request.auth.uid == resource.data.to;
    }

    /* =================== CONTENT + RATINGS =================== */
    match /content/{contentId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.authorId is string
        && request.resource.data.type in ['post', 'story', 'clip'];

      allow update, delete: if request.auth != null
        && resource.data.authorId == request.auth.uid;

      match /ratings/{raterId} {
        allow read: if request.auth != null;

        allow create: if request.auth != null
          && raterId == request.auth.uid
          && request.resource.data.raterId == request.auth.uid
          && request.resource.data.authorId != request.auth.uid
          && request.resource.data.value is int
          && request.resource.data.value >= 1
          && request.resource.data.value <= 5
          && exists(/databases/$(database)/documents/content/$(contentId));

        allow update: if request.auth != null
          && raterId == request.auth.uid
          && request.resource.data.raterId == request.auth.uid
          && request.resource.data.value is int
          && request.resource.data.value >= 1
          && request.resource.data.value <= 5;

        allow delete: if false;
      }
    }

    /* =================== USER STATS =================== */
    match /userStats/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    /* =================== catch-all =================== */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
