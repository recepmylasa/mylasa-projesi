{
  "name": "Mylasa",
  "short_name": "Mylasa",
  "description": "mylasa sosyal",
  "id": "/mylasa?v=4",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui"],
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "capture_links": "existing-client-event",
  "background_color": "#ffffff",
  "theme_color": "#6b5cff",
  "icons": [
    {
      "src": "/logo192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/logo512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+mylasa",
      "url": "/open-route?query=%s"
    }
  ]
}
